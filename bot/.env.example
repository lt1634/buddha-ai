# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# LLM API (NVIDIA NIM — 免費)
LLM_API_KEY=your_nvidia_nim_api_key
LLM_BASE_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=meta/llama-4-maverick-17b-128e-instruct
LLM_MAX_TOKENS=4000

# 可選 model（用 /model 命令切換）:
# meta/llama-4-maverick-17b-128e-instruct  ← 預設，最穩
# qwen/qwen3.5-397b-a17b                  ← Code 最強
# z-ai/glm-5.2                            ← Reasoning（免費但穩定性一般）
