# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# LLM API（opencode.ai zen — 同 Hermes agent）
LLM_API_KEY=your_opencode_api_key
LLM_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL=mimo-v2.5
LLM_MAX_TOKENS=4000

# 可選 model（用 /model 命令切換）:
# mimo-v2.5                               ← 預設
# glm-5.2
# maverick / qwen                        ← 需改 LLM_BASE_URL 去 NVIDIA NIM

# 管理員 Telegram user ID（逗號分隔；/log 指令用）
# ADMIN_TELEGRAM_IDS=123456789
